APP_ENV=development
DEBUG=true

DATABASE_URL=postgresql+asyncpg://rpg_manager:rpg_manager@db:5432/rpg_manager
DATABASE_URL_SYNC=postgresql+psycopg2://rpg_manager:rpg_manager@db:5432/rpg_manager

JWT_SECRET=dev-only-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
PASSWORD_MIN_LENGTH=8

CORS_ORIGINS=http://localhost:3000,http://localhost:8011,http://localhost:8080
