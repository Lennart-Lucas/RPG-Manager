APP_ENV=production
DEBUG=false

POSTGRES_USER=rpg_manager
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=rpg_manager

DATABASE_URL=postgresql+asyncpg://rpg_manager:change-me-to-a-strong-password@db:5432/rpg_manager
DATABASE_URL_SYNC=postgresql+psycopg2://rpg_manager:change-me-to-a-strong-password@db:5432/rpg_manager

